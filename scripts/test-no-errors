#!/bin/bash
# test-no-errors: verify tree-sitter parses all spec documents without ERROR nodes.
#
# Parses every .lex file in comms/specs/ and checks for ERROR nodes in the
# output. Any ERROR node is a failure — no allowlists, no exceptions.
#
# The lex-core reference parser handles all these files gracefully (falling
# back to paragraph for unparseable content). Tree-sitter should too — an
# ERROR node means the grammar can't handle something that valid lex documents
# contain.
#
# Exit 0 = all clean, exit 1 = any file has ERROR nodes.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "test-no-errors: parse all spec fixtures"
echo ""

cd "$REPO_DIR"

PASS=0
FAIL=0
TOTAL_ERRORS=0
FAILURES=""

while IFS= read -r f; do
    rel="${f#$REPO_DIR/comms/specs/}"
    parse_output=$(npx tree-sitter parse "$f" 2>/dev/null) || true

    if [[ -z "$parse_output" ]]; then
        printf "  %-70s \033[31mFAIL\033[0m (no output)\n" "$rel"
        FAIL=$((FAIL + 1))
        FAILURES="${FAILURES}\n  ${rel} (no output)"
        continue
    fi

    error_count=$(echo "$parse_output" | grep -c "ERROR" || true)

    if [[ "$error_count" -eq 0 ]]; then
        printf "  %-70s \033[32mPASS\033[0m\n" "$rel"
        PASS=$((PASS + 1))
    else
        printf "  %-70s \033[31mFAIL\033[0m (%d errors)\n" "$rel" "$error_count"
        FAIL=$((FAIL + 1))
        TOTAL_ERRORS=$((TOTAL_ERRORS + error_count))
        FAILURES="${FAILURES}\n  ${rel} (${error_count} errors)"
    fi
done < <(find "$REPO_DIR/comms/specs" -name "*.lex" | sort)

echo ""
echo "────────────"
printf "Results: \033[32m%d passed\033[0m, \033[31m%d failed\033[0m" "$PASS" "$FAIL"
if [[ $TOTAL_ERRORS -gt 0 ]]; then
    printf " (%d total ERROR nodes)" "$TOTAL_ERRORS"
fi
echo ""

if [[ $FAIL -gt 0 ]]; then
    printf "\nFailed files:%b\n" "$FAILURES"
    exit 1
fi
