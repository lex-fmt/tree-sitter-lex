#!/bin/bash
# test-parity: compare tree-sitter CST with lex-core AST.
#
# Both parsers render to a plain-text "block skeleton" format and the output
# is diffed. Files listed in parity-ignored.txt are expected to differ — they
# are real divergences we've acknowledged, not "passing" tests.
#
# Downloads lex-cli if not available. Never skips.
#
# Exit 0 = no unexpected divergences, exit 1 = any non-ignored file differs.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PRINTER="$SCRIPT_DIR/parity-print.js"
IGNORE_LIST="$SCRIPT_DIR/parity-ignored.txt"

echo "test-parity: CST vs AST comparison"
echo ""

# --- Resolve lex-cli (download if needed) ---
LEX_CLI="${LEX_CLI_PATH:-}"
if [[ -z "$LEX_CLI" ]] && [[ -f "$REPO_DIR/bin/lex" ]]; then
    LEX_CLI="$REPO_DIR/bin/lex"
fi
if [[ -z "$LEX_CLI" ]]; then
    echo "  lex-cli not found, downloading..."
    LEX_CLI=$("$SCRIPT_DIR/download-lex-cli.sh" 2>/dev/null | tail -1)
fi
if [[ -z "$LEX_CLI" ]] || [[ ! -x "$LEX_CLI" ]]; then
    echo "Error: could not obtain lex-cli binary." >&2
    exit 1
fi
echo "  Using lex-cli: $LEX_CLI ($($LEX_CLI --version 2>&1))"
echo ""

# --- Load ignored files ---
IGNORED=""
if [[ -f "$IGNORE_LIST" ]]; then
    while IFS= read -r line; do
        line="${line%%#*}"
        line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [[ -z "$line" ]] && continue
        IGNORED="${IGNORED}|${line}"
    done < "$IGNORE_LIST"
fi

is_ignored() {
    echo "$IGNORED" | grep -qF "|${1}"
}

# --- Run comparison ---
VERBOSE=false
SINGLE_FILE=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --verbose|-v) VERBOSE=true; shift ;;
        *) SINGLE_FILE="$1"; shift ;;
    esac
done

MATCH=0
DIFFER_IGNORED=0
DIFFER_UNEXPECTED=0
ERRORS=""

check_file() {
    local lex_file="$1"
    local rel_path="${lex_file#$REPO_DIR/}"

    # Reference output
    local lex_output
    lex_output=$("$LEX_CLI" inspect "$lex_file" parity 2>/dev/null) || {
        printf "  %-65s \033[31mFAIL\033[0m (lex-cli error)\n" "$rel_path"
        DIFFER_UNEXPECTED=$((DIFFER_UNEXPECTED + 1))
        ERRORS="${ERRORS}\n  ${rel_path} (lex-cli error)"
        return
    }

    # Tree-sitter output
    local ts_output
    ts_output=$(cd "$REPO_DIR" && npx tree-sitter parse -x "$lex_file" 2>/dev/null | node "$PRINTER" 2>/dev/null) || {
        printf "  %-65s \033[31mFAIL\033[0m (tree-sitter error)\n" "$rel_path"
        DIFFER_UNEXPECTED=$((DIFFER_UNEXPECTED + 1))
        ERRORS="${ERRORS}\n  ${rel_path} (tree-sitter error)"
        return
    }

    if diff <(echo "$lex_output") <(echo "$ts_output") > /dev/null 2>&1; then
        printf "  %-65s \033[32mMATCH\033[0m\n" "$rel_path"
        MATCH=$((MATCH + 1))
    elif is_ignored "$rel_path"; then
        printf "  %-65s \033[33mIGNORED\033[0m\n" "$rel_path"
        DIFFER_IGNORED=$((DIFFER_IGNORED + 1))
    else
        printf "  %-65s \033[31mDIFFER\033[0m\n" "$rel_path"
        DIFFER_UNEXPECTED=$((DIFFER_UNEXPECTED + 1))
        ERRORS="${ERRORS}\n  ${rel_path}"
        if $VERBOSE; then
            echo "  --- lex-core (left) vs tree-sitter (right) ---"
            diff --color=always <(echo "$lex_output") <(echo "$ts_output") | head -30
            echo ""
        fi
    fi
}

if [[ -n "$SINGLE_FILE" ]]; then
    check_file "$SINGLE_FILE"
else
    for f in "$REPO_DIR"/comms/specs/elements/**/*.lex; do
        check_file "$f"
    done
fi

TOTAL=$((MATCH + DIFFER_IGNORED + DIFFER_UNEXPECTED))
echo ""
echo "────────────"
printf "Results: \033[32m%d match\033[0m, \033[33m%d ignored\033[0m, \033[31m%d differ\033[0m (out of %d files)\n" \
    "$MATCH" "$DIFFER_IGNORED" "$DIFFER_UNEXPECTED" "$TOTAL"

if [[ $TOTAL -gt 0 ]]; then
    pct=$((MATCH * 100 / TOTAL))
    echo "Parity: ${pct}%"
fi

if [[ $DIFFER_UNEXPECTED -gt 0 ]]; then
    printf "\nUnexpected divergences:%b\n" "$ERRORS"
    exit 1
fi
