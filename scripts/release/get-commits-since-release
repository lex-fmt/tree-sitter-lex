#!/usr/bin/env bash
# get-commits-since-release — print commits made since the most recent
# `vX.Y.Z` tag, one per line, in `<short-sha> <subject>` format.
#
# Empty stdout = no new commits since last release (caller decides if that's
# an error or a no-op).
#
# Layer 0 release primitive — see lex-fmt/lex#640. Used by higher-layer
# release tooling to decide whether a bump is warranted and to populate
# changelogs.
#
# Notes:
#   - Only `vX.Y.Z` tags count; pre-release / RC tags are intentionally
#     ignored to keep the "released" baseline unambiguous.
#   - If no matching tag exists yet, falls back to the repo's root commit
#     so a fresh repo still produces useful output.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$REPO_ROOT"

# Pick the highest semver tag matching vX.Y.Z. `--sort=-v:refname` orders
# tags by version descending; head -n1 grabs the most recent.
LAST_TAG="$(git tag --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname \
  | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' \
  | head -n1 || true)"

if [[ -z "$LAST_TAG" ]]; then
  # No release tag yet — list everything reachable from HEAD.
  RANGE="HEAD"
else
  RANGE="${LAST_TAG}..HEAD"
fi

git log --pretty=format:'%h %s' "$RANGE"
# Ensure trailing newline even when git log omits it on non-empty output.
# (git log --pretty doesn't print a trailing \n; empty output stays empty.)
if [[ -n "$(git log --pretty=format:'%h' "$RANGE")" ]]; then
  echo
fi
