#!/usr/bin/env bash
# update-release <new-version> — apply <new-version> to every version-bearing
# file in this repo and `git add` the touched files. The caller is responsible
# for inspecting the staged diff and creating the commit + tag (typically via
# scripts/create-release or the higher-layer release pipeline).
#
# <new-version> is bare (no leading `v`). Validated as semver-ish: X.Y.Z with
# optional `-<pre>` and `+<build>` suffixes.
#
# Layer 0 release primitive — see lex-fmt/lex#640. Sister scripts:
#   - get-current-version
#   - get-commits-since-release
#
# Files updated in tree-sitter-lex:
#   - package.json              `.version`
#   - tree-sitter.json          `.metadata.version`
#   - CHANGELOG.md              consume UNRELEASED.md → prepend `## vX.Y.Z (YYYY-MM-DD)`
#   - UNRELEASED.md             reset to the empty template
#   - comms (submodule)         fast-forward to origin/main, stage the gitlink
#
# This repo has no Cargo.toml — skipped.
#
# Idempotency: re-running with the same version is a no-op for most files
# (jq writes the same bytes deterministically) but CHANGELOG/UNRELEASED move
# state, so don't do that. The script doesn't currently guard against it —
# caller responsibility.
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  <new-version>  bare semver, e.g. 0.11.0" >&2
}

if [[ $# -ne 1 ]]; then
  usage
  exit 1
fi

NEW_VERSION="$1"

# Bare semver: X.Y.Z with optional -<pre> and +<build>. Reject leading `v`.
if [[ ! "$NEW_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$ ]]; then
  echo "error: <new-version> must be bare semver X.Y.Z (got: $NEW_VERSION)" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$REPO_ROOT"

DATE="$(date +%Y-%m-%d)"
TAG="v${NEW_VERSION}"

# Helper: rewrite a single JSON field via jq, verify the write took, then
# git-add the file. Using `jq` (rather than a targeted sed) means a successful
# exit guarantees the field was actually updated — sed silently no-ops if the
# regex doesn't match, which is too easy to miss.
#
# The previous implementation used sed to avoid jq's whole-file normalization
# (short-array expansion, etc.); we now accept that diff noise in exchange for
# a write that's verifiable by the script itself. The version-bump commit
# touches these files anyway, so the noise lands in a release-only diff.
update_json_field() {
  local file="$1" path="$2" value="$3"
  local tmp
  # Sanity check: field must exist before we overwrite it.
  jq -e "$path" "$file" >/dev/null
  tmp="$(mktemp "${file}.XXXXXX")"
  jq --arg v "$value" "$path = \$v" "$file" > "$tmp"
  mv "$tmp" "$file"
  # Verify: re-read the field and assert it matches what we asked for.
  local got
  got="$(jq -er "$path" "$file")"
  if [[ "$got" != "$value" ]]; then
    echo "error: failed to update $path in $file (got: $got, want: $value)" >&2
    exit 1
  fi
  git add "$file"
}

# --- package.json ---------------------------------------------------------
update_json_field "$REPO_ROOT/package.json" '.version' "$NEW_VERSION"

# --- tree-sitter.json -----------------------------------------------------
# Tree-sitter's metadata block carries its own version field. Keep in lockstep
# with package.json so downstream consumers (editors that parse tree-sitter.json)
# don't see a stale number.
TS_JSON="$REPO_ROOT/tree-sitter.json"
if [[ -f "$TS_JSON" ]] && jq -e '.metadata.version' "$TS_JSON" >/dev/null 2>&1; then
  update_json_field "$TS_JSON" '.metadata.version' "$NEW_VERSION"
fi

# --- CHANGELOG.md + UNRELEASED.md ----------------------------------------
# This repo's convention (see scripts/create-release): release notes live in
# UNRELEASED.md while a version is in flight, then get prepended to
# CHANGELOG.md as `## vX.Y.Z (YYYY-MM-DD)` at release time. We mirror that
# behavior here so update-release is a drop-in for higher-layer tooling.
CHANGELOG="$REPO_ROOT/CHANGELOG.md"
UNRELEASED="$REPO_ROOT/UNRELEASED.md"

if [[ -f "$UNRELEASED" ]]; then
  # Strip HTML comment lines, trim leading/trailing blank lines.
  # `|| true` because grep exits non-zero when nothing matches (template-only
  # UNRELEASED.md), and we want the variable to land as the empty string
  # instead of tripping `set -e`.
  NOTES="$( { grep -v '^<!--.*-->$' "$UNRELEASED" || true; } \
    | sed -e '/./,$!d' -e :a -e '/^\n*$/{$d;N;ba' -e '}')"
else
  NOTES=""
fi

if [[ -n "$NOTES" ]]; then
  ENTRY="## ${TAG} (${DATE})

${NOTES}"
else
  # No notes accumulated — still record the version bump so the CHANGELOG
  # stays a complete release history. Higher-layer tooling is expected to
  # surface a warning when this branch is taken.
  ENTRY="## ${TAG} (${DATE})

- (no release notes recorded)"
fi

if [[ -f "$CHANGELOG" ]]; then
  # Preserve header line, insert new entry after it.
  TAIL="$(tail -n +2 "$CHANGELOG")"
  printf '%s\n\n%s\n%s\n' "# Changelog" "$ENTRY" "$TAIL" > "$CHANGELOG"
else
  printf '%s\n\n%s\n' "# Changelog" "$ENTRY" > "$CHANGELOG"
fi
git add "$CHANGELOG"

# Reset UNRELEASED.md to the empty template so the next cycle starts clean.
cat > "$UNRELEASED" <<'TEMPLATE'
<!-- Release notes for the next version. -->
<!-- Updated as work is done; consumed by scripts/create-release. -->
TEMPLATE
git add "$UNRELEASED"

# --- comms submodule ------------------------------------------------------
# Fast-forward the comms submodule to origin/main and stage the gitlink. This
# matches the rest of the lex-fmt portfolio (lex, vscode, nvim, lexed all do
# the same dance at release time so the bundled specs match the published
# release).
if [[ -d "$REPO_ROOT/comms/.git" ]] || [[ -f "$REPO_ROOT/comms/.git" ]]; then
  (
    cd "$REPO_ROOT/comms"
    git fetch origin
    git checkout origin/main
  )
  git add comms
fi

echo "Staged version bump to ${NEW_VERSION}. Review with: git diff --cached" >&2
