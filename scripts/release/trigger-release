#!/usr/bin/env bash
# trigger-release — Layer 0 release-trigger primitive (tree-sitter-lex).
#
# Role
# ----
# Fourth of the four Layer 0 release primitives in the cross-repo release
# orchestration system (tracking issue: lex-fmt/lex#640). The orchestrator
# script (Layer 1, lives in arthur-debert/release) calls this after a
# version-bump PR has been merged on `main` to actually fire the release.
#
# Strategy: tag-push
# ------------------
# This repo's release CI (.github/workflows/release.yml) is wired to:
#     on: push: tags: [v*]
# so the trigger is simply: create an annotated-or-lightweight `vX.Y.Z` tag
# on the current HEAD (expected to be the merged version-bump commit on
# `main`) and push it to `origin`. CI takes over from there — building the
# tree-sitter.tar.gz release artifact and publishing the GitHub release.
#
# Contract
# --------
# - Input:  a single bare semver string (e.g. `0.10.2`, NO leading `v`).
# - Side effects: creates local tag `vX.Y.Z`, pushes it to `origin`.
# - Exit codes:
#     0  tag created + pushed
#     1  tag already exists locally (refuse to clobber)
#     2  bad usage / malformed version
#
# This is intentionally dumb: it does not bump versions, does not edit
# files, does not consult CHANGELOG. All of that is the orchestrator's job
# (and the version-bump PR's job). This primitive just fires the trigger.
#
# Sibling primitives in this repo: get-current-version,
# get-commits-since-release, update-release.

set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  new-version   Bare semver string, e.g. 0.8.1 (no leading v)" >&2
}

[[ $# -ne 1 ]] && { usage; exit 2; }
NEW_VERSION="$1"
[[ ! "$NEW_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] && { echo "error: version must be X.Y.Z" >&2; exit 2; }

TAG="v$NEW_VERSION"
if git rev-parse "$TAG" >/dev/null 2>&1; then
  echo "error: tag $TAG already exists locally — delete it or pick a new version" >&2
  exit 1
fi

echo "Tagging $TAG on $(git rev-parse --short HEAD)..."
git tag "$TAG"
echo "Pushing $TAG to origin..."
git push origin "$TAG"
echo "Done. CI should pick it up shortly."
