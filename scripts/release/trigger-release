#!/usr/bin/env bash
# trigger-release — Layer 0 release-trigger primitive (tree-sitter-lex).
#
# Role
# ----
# Fourth of the four Layer 0 release primitives in the cross-repo release
# orchestration system (tracking issue: lex-fmt/lex#640). The orchestrator
# script (Layer 1, lives in arthur-debert/release) calls this after a
# version-bump PR has been merged on `main` to actually fire the release.
#
# Strategy: workflow_dispatch
# ---------------------------
# This repo's release CI (.github/workflows/release.yml) is wired to:
#     on: workflow_dispatch
# matching the cross-repo cascade-handler trigger contract. It is a thin
# caller of arthur-debert/release/.github/workflows/tree-sitter.yml@v1
# which handles the version bump, changelog roll, tag + push, build, and
# GH release. No local tag-and-push needed.
#
# Migration note (2026-05-18): previously this primitive used the
# tag-push strategy. The migration to release@v1.6.0 moved the trigger
# contract to workflow_dispatch — same as vscode, mkdocs-lex, and the
# rest of the lex-release cascade.
#
# Contract
# --------
# - Input:  a single bare semver string (e.g. `0.11.0`, NO leading `v`).
# - Side effects: fires the release workflow_dispatch event.
# - Exit codes:
#     0  workflow_dispatch event fired
#     1  gh CLI missing or workflow dispatch errored
#     2  bad usage / malformed version
#
# Sibling primitives in this repo: get-current-version,
# get-commits-since-release, update-release.

set -euo pipefail

if ! command -v gh >/dev/null 2>&1; then
  echo "error: gh is required but not installed" >&2
  exit 1
fi

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  new-version   Bare semver string, e.g. 0.11.0 (no leading v)" >&2
}

[[ $# -ne 1 ]] && { usage; exit 2; }
NEW_VERSION="$1"
if ! [[ "${NEW_VERSION}" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$ ]]; then
  echo "error: version must be X.Y.Z[-PRERELEASE]" >&2
  exit 2
fi

echo "Triggering release workflow for v${NEW_VERSION}..."
gh workflow run release.yml -f "version=${NEW_VERSION}"
echo "Done. CI should pick it up shortly."
echo "Watch: gh run list --workflow=release.yml --limit 1"
