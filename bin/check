#!/usr/bin/env bash
set -euo pipefail

# Canonical tree-sitter check entry point. Same script local + CI.
#
# Delegates to scripts/test-all if present. The lex-fmt/tree-sitter-lex
# repo has scripts/test-all wired as the umbrella; consumers without it
# can fall back to the standard tree-sitter test cycle.

die() {
    echo "$1" >&2
    exit 2
}

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

if [ -x scripts/test-all ]; then
    exec scripts/test-all "$@"
fi

command -v npx >/dev/null 2>&1 || die "bin/check: npx not found on \$PATH (tree-sitter CLI is npm-based)"

npx tree-sitter generate
exec npx tree-sitter test "$@"
