node_modules/
# Downloaded runtime/test deps (lexd binary) live here, not in bin/.
/deps/
# Allow bin/<verb> thin callers (per arthur-debert/release).
/bin/*
!/bin/check
!/bin/build
!/bin/changelog
!/bin/changelog-add
!/bin/changelog-cut
!/bin/changelog-render
*.wasm
# package-lock.json is COMMITTED (see below): a lockfile makes node-deps
# installs deterministic — CI's tree-sitter-ci.yml switches from `npm install`
# to `npm ci` when it is present, and shipit tree provisioning (#543) needs a
# recognized lockfile (or a packageManager pin) to pick a frozen install
# instead of refusing.
.padz
.deps/
