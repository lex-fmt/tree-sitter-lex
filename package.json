{
  "name": "tree-sitter-lex",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Lex document format",
  "main": "bindings/node",
  "repository": {
    "type": "git",
    "url": "https://github.com/lex-fmt/tree-sitter-lex"
  },
  "keywords": ["parser", "tree-sitter", "lex"],
  "license": "MIT",
  "tree-sitter": [
    {
      "scope": "source.lex",
      "file-types": ["lex"],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  }
}
